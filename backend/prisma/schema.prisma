// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Usuario {
  id              String      @id @default(cuid())
  email           String      @unique
  password        String
  rol             Rol
  cuit            String?     @unique
  nombre          String
  apellido        String?
  empresa         String?
  telefono        String?
  activo          Boolean     @default(true)
  esInspector     Boolean     @default(false)
  dosFaSecret     String?
  dosFaVerificado Boolean     @default(false)
  notifNuevoRegistro      Boolean   @default(true)
  notifEmail              Boolean   @default(true)
  notifWhatsapp           Boolean   @default(false)
  notifTelegram           Boolean   @default(false)
  telegramChatId          String?
  whatsappPhone           String?
  emailVerified           Boolean   @default(false)
  emailVerificationToken  String?
  passwordResetToken      String?
  passwordResetExpires    DateTime?
  intentosFallidos        Int       @default(0)
  bloqueadoHasta          DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  // Relaciones
  generador       Generador?
  transportista   Transportista?
  operador        Operador?
  refreshTokens   RefreshToken[]
  manifiestosCreados Manifiesto[]    @relation("UsuarioManifiestos")
  eventos         EventoManifiesto[]
  auditorias      Auditoria[]         @relation("UsuarioAuditorias")
  notificaciones    Notificacion[]
  reglasCreadas     ReglaAlerta[]       @relation("ReglasCreadas")
  solicitudes       SolicitudInscripcion[]
  pushSubscripciones PushSubscripcion[]

  @@map("usuarios")
}

model Generador {
  id                String      @id @default(cuid())
  usuarioId         String      @unique
  razonSocial       String
  cuit              String      @unique
  domicilio         String
  telefono          String
  email             String
  numeroInscripcion String
  categoria         String
  actividad         String?
  rubro             String?
  corrientesControl String?
  latitud           Float?
  longitud          Float?
  activo            Boolean     @default(true)
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  // Campos regulatorios DPA Mendoza
  expedienteInscripcion   String?
  domicilioLegalCalle     String?
  domicilioLegalLocalidad String?
  domicilioLegalDepto     String?
  domicilioRealCalle      String?
  domicilioRealLocalidad  String?
  domicilioRealDepto      String?
  certificacionISO        DateTime?
  resolucionInscripcion   String?
  factorR                 Float?
  montoMxR                Float?
  categoriaIndividual     String?
  libroOperatoria         Boolean?
  tefInputs               Json?

  // Relaciones
  usuario     Usuario      @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  manifiestos Manifiesto[]
  pagos       PagoTEF[]
  ddjj        DeclaracionJurada[]
  documentos  Documento[]
  renovaciones Renovacion[]

  @@map("generadores")
}

model Transportista {
  id                  String    @id @default(cuid())
  usuarioId           String    @unique
  razonSocial         String
  cuit                String    @unique
  domicilio           String
  telefono            String
  email               String
  numeroHabilitacion  String
  latitud             Float?
  longitud            Float?
  activo              Boolean   @default(true)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  // Campos regulatorios DPA Mendoza (migración 2026-03-13)
  localidad               String?    // Municipio/ciudad (LOC. del Excel)
  vencimientoHabilitacion DateTime?  // VTO. del certificado CAA
  corrientesAutorizadas   String?    // Corrientes Basilea raw: "Y4/Y8/Y9/..."
  expedienteDPA           String?    // Expediente DPA (EXPTE. DPA)
  resolucionDPA           String?    // Resolución DPA (ej: "0359/24")
  resolucionSSP           String?    // Resolución SSP
  actaInspeccion          String?    // Acta de Inspección (ej: "rp-g000040")
  actaInspeccion2         String?    // Segunda Acta de Inspección

  // Relaciones
  usuario       Usuario      @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  vehiculos     Vehiculo[]
  choferes      Chofer[]
  manifiestos   Manifiesto[]

  @@map("transportistas")
}

model Operador {
  id                  String    @id @default(cuid())
  usuarioId           String    @unique
  razonSocial         String
  cuit                String    @unique
  domicilio           String
  telefono            String
  email               String
  numeroHabilitacion  String
  categoria           String
  tipoOperador        String?
  tecnologia          String?
  corrientesY         String?
  modalidades         String[]  @default(["FIJO"])
  latitud             Float?
  longitud            Float?
  activo              Boolean   @default(true)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  // Campos enriquecidos DPA Mendoza
  expedienteInscripcion       String?
  certificadoNumero           String?
  domicilioLegalCalle         String?
  domicilioLegalLocalidad     String?
  domicilioLegalDepto         String?
  domicilioRealCalle          String?
  domicilioRealLocalidad      String?
  domicilioRealDepto          String?
  representanteLegalNombre    String?
  representanteLegalDNI       String?
  representanteLegalTelefono  String?
  representanteTecnicoNombre  String?
  representanteTecnicoMatricula String?
  representanteTecnicoTelefono  String?
  vencimientoHabilitacion     DateTime?
  resolucionDPA               String?
  tefInputs                   Json?

  // Relaciones
  usuario       Usuario              @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  tratamientos  TratamientoAutorizado[]
  manifiestos   Manifiesto[]
  sedes         SedeOperador[]
  documentos    Documento[]
  pagos         PagoTEF[]
  ddjj          DeclaracionJurada[]
  renovaciones  Renovacion[]

  @@map("operadores")
}

model Vehiculo {
  id              String      @id @default(cuid())
  transportistaId String
  patente         String
  marca           String
  modelo          String
  anio            Int
  capacidad       Float
  numeroHabilitacion String
  vencimiento     DateTime
  activo          Boolean     @default(true)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  // Relaciones
  transportista Transportista @relation(fields: [transportistaId], references: [id], onDelete: Cascade)

  @@map("vehiculos")
}

model Chofer {
  id              String      @id @default(cuid())
  transportistaId String
  nombre          String
  apellido        String
  dni             String
  licencia        String
  vencimiento     DateTime
  telefono        String
  activo          Boolean     @default(true)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  // Relaciones
  transportista Transportista @relation(fields: [transportistaId], references: [id], onDelete: Cascade)

  @@map("choferes")
}

model TipoResiduo {
  id              String      @id @default(cuid())
  codigo          String      @unique
  nombre          String
  descripcion     String?
  categoria       String
  caracteristicas String?
  peligrosidad    String
  activo          Boolean     @default(true)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  // Relaciones
  manifiestos     ManifiestoResiduo[]
  tratamientos    TratamientoAutorizado[]

  @@map("tipos_residuos")
}

model Manifiesto {
  id              String      @id @default(cuid())
  numero          String      @unique
  generadorId     String
  transportistaId String?
  operadorId      String
  modalidad       String?   @default("FIJO")
  tratamientoMetodo         String?
  tratamientoAutorizadoId   String?
  estado          EstadoManifiesto @default(BORRADOR)
  observaciones   String?
  fechaFirma      DateTime?
  fechaEstimadaRetiro DateTime?
  fechaRetiro     DateTime?
  fechaEntrega    DateTime?
  fechaRecepcion  DateTime?
  fechaCierre     DateTime?
  qrCode          String?
  blockchainHash        String?
  blockchainTxHash      String?
  blockchainBlockNumber Int?
  blockchainTimestamp   DateTime?
  blockchainStatus      String?
  blockchainRetries     Int       @default(0)
  rollingHash           String?
  isDemoData      Boolean     @default(false)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  // Relaciones
  generador       Generador           @relation(fields: [generadorId], references: [id])
  transportista   Transportista?      @relation(fields: [transportistaId], references: [id])
  operador        Operador            @relation(fields: [operadorId], references: [id])
  creadoPor       Usuario             @relation("UsuarioManifiestos", fields: [creadoPorId], references: [id])
  creadoPorId     String
  residuos        ManifiestoResiduo[]
  eventos         EventoManifiesto[]
  tracking        TrackingGPS[]
  auditorias      Auditoria[]
  notificaciones  Notificacion[]
  alertas         AlertaGenerada[]
  anomalias       AnomaliaTransporte[]
  sellosBlockchain BlockchainSello[]

  @@index([generadorId])
  @@index([transportistaId])
  @@index([operadorId])
  @@index([estado])
  @@index([createdAt])
  @@index([estado, createdAt])
  @@index([numero])
  @@index([transportistaId, estado])
  @@map("manifiestos")
}

model ManifiestoResiduo {
  id              String      @id @default(cuid())
  manifiestoId    String
  tipoResiduoId   String
  cantidad        Float
  unidad          String
  cantidadRecibida Float?
  tipoDiferencia  TipoDiferencia?
  observaciones   String?
  descripcion     String?
  estado          String
  createdAt       DateTime    @default(now())

  // Relaciones
  manifiesto    Manifiesto    @relation(fields: [manifiestoId], references: [id], onDelete: Cascade)
  tipoResiduo   TipoResiduo   @relation(fields: [tipoResiduoId], references: [id])

  @@index([manifiestoId])
  @@map("manifiestos_residuos")
}

enum TipoDiferencia {
  FALTANTE
  EXCEDENTE
  NINGUNA
}

model EventoManifiesto {
  id              String      @id @default(cuid())
  manifiestoId    String
  tipo            String
  descripcion     String
  ubicacion       String?
  latitud         Float?
  longitud        Float?
  usuarioId       String
  integrityHash   String?
  isDemoData      Boolean     @default(false)
  createdAt       DateTime    @default(now())

  // Relaciones
  manifiesto    Manifiesto    @relation(fields: [manifiestoId], references: [id], onDelete: Cascade)
  usuario       Usuario       @relation(fields: [usuarioId], references: [id])

  @@index([manifiestoId])
  @@index([manifiestoId, tipo])
  @@map("eventos_manifiesto")
}

model TrackingGPS {
  id              String      @id @default(cuid())
  manifiestoId    String
  latitud         Float
  longitud        Float
  velocidad       Float?
  direccion       Float?
  precision       Float?
  isDemoData      Boolean     @default(false)
  timestamp       DateTime    @default(now())

  // Relaciones
  manifiesto    Manifiesto    @relation(fields: [manifiestoId], references: [id], onDelete: Cascade)

  @@index([manifiestoId])
  @@index([manifiestoId, timestamp])
  @@map("tracking_gps")
}

model TratamientoAutorizado {
  id              String      @id @default(cuid())
  operadorId      String
  tipoResiduoId   String
  metodo          String
  descripcion     String?
  capacidad       Float?
  activo          Boolean     @default(true)
  fechaAutorizacion    DateTime?
  fechaVencimiento     DateTime?
  numeroResolucion     String?
  expediente           String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  // Relaciones
  operador      Operador      @relation(fields: [operadorId], references: [id], onDelete: Cascade)
  tipoResiduo   TipoResiduo   @relation(fields: [tipoResiduoId], references: [id])

  @@unique([operadorId, tipoResiduoId, metodo])
  @@map("tratamientos_autorizados")
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  usuarioId String
  revocado  Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relaciones
  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

model Auditoria {
  id              String      @id @default(cuid())
  accion          String
  modulo          String
  datosAntes      String?
  datosDespues    String?
  ip              String?
  userAgent       String?
  usuarioId       String?
  manifiestoId    String?
  generadorId     String?
  operadorId      String?
  transportistaId String?
  createdAt       DateTime    @default(now())

  // Relaciones
  usuario     Usuario?    @relation("UsuarioAuditorias", fields: [usuarioId], references: [id], onDelete: SetNull)
  manifiesto  Manifiesto? @relation(fields: [manifiestoId], references: [id])

  @@index([manifiestoId])
  @@index([createdAt])
  @@index([generadorId])
  @@index([operadorId])
  @@index([transportistaId])
  @@map("auditorias")
}

model SedeOperador {
  id           String   @id @default(cuid())
  operadorId   String
  nombre       String
  tipo         String   @default("FIJO")
  domicilio    String
  localidad    String?
  departamento String?
  latitud      Float?
  longitud     Float?
  activo       Boolean  @default(true)
  createdAt    DateTime @default(now())
  operador     Operador @relation(fields: [operadorId], references: [id])

  @@map("sedes_operador")
}

// Enumeraciones
enum Rol {
  ADMIN
  GENERADOR
  TRANSPORTISTA
  OPERADOR
  ADMIN_TRANSPORTISTA
  ADMIN_GENERADOR
  ADMIN_OPERADOR
}

enum EstadoManifiesto {
  BORRADOR
  PENDIENTE_APROBACION
  APROBADO
  EN_TRANSITO
  ENTREGADO
  RECIBIDO
  EN_TRATAMIENTO
  TRATADO
  RECHAZADO
  CANCELADO
}

// ========== SISTEMA DE NOTIFICACIONES IN-APP ==========

model Notificacion {
  id              String              @id @default(cuid())
  usuarioId       String
  tipo            TipoNotificacion
  titulo          String
  mensaje         String
  datos           String?             // JSON con datos adicionales
  manifiestoId    String?
  leida           Boolean             @default(false)
  fechaLeida      DateTime?
  prioridad       PrioridadNotificacion @default(NORMAL)
  createdAt       DateTime            @default(now())

  // Relaciones
  usuario         Usuario             @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  manifiesto      Manifiesto?         @relation(fields: [manifiestoId], references: [id])

  @@index([usuarioId, leida])
  @@map("notificaciones")
}

model ReglaAlerta {
  id              String              @id @default(cuid())
  nombre          String
  descripcion     String?
  evento          EventoAlerta
  condicion       String              // JSON con condiciones
  destinatarios   String              // JSON con roles/usuarios
  activa          Boolean             @default(true)
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  creadoPorId     String

  // Relaciones
  creadoPor       Usuario             @relation("ReglasCreadas", fields: [creadoPorId], references: [id])
  alertasGeneradas AlertaGenerada[]

  @@map("reglas_alertas")
}

model AlertaGenerada {
  id              String              @id @default(cuid())
  reglaId         String
  manifiestoId    String?
  datos           String              // JSON con datos del evento
  estado          EstadoAlerta        @default(PENDIENTE)
  resueltaPor     String?
  fechaResolucion DateTime?
  notas           String?
  createdAt       DateTime            @default(now())

  // Relaciones
  regla           ReglaAlerta         @relation(fields: [reglaId], references: [id])
  manifiesto      Manifiesto?         @relation(fields: [manifiestoId], references: [id])

  @@index([manifiestoId])
  @@index([estado])
  @@map("alertas_generadas")
}

model AnomaliaTransporte {
  id              String              @id @default(cuid())
  manifiestoId    String
  tipo            TipoAnomalia
  descripcion     String
  latitud         Float
  longitud        Float
  valorDetectado  Float?
  valorEsperado   Float?
  severidad       SeveridadAnomalia   @default(MEDIA)
  resuelta        Boolean             @default(false)
  resueltaPor     String?
  fechaResolucion DateTime?
  notas           String?
  isDemoData      Boolean             @default(false)
  createdAt       DateTime            @default(now())

  // Relaciones
  manifiesto      Manifiesto          @relation(fields: [manifiestoId], references: [id])

  @@index([manifiestoId])
  @@map("anomalias_transporte")
}

// Enumeraciones adicionales
enum TipoNotificacion {
  MANIFIESTO_FIRMADO
  MANIFIESTO_EN_TRANSITO
  MANIFIESTO_ENTREGADO
  MANIFIESTO_RECIBIDO
  MANIFIESTO_TRATADO
  MANIFIESTO_RECHAZADO
  INCIDENTE_REPORTADO
  ANOMALIA_DETECTADA
  VENCIMIENTO_PROXIMO
  ALERTA_SISTEMA
  INFO_GENERAL
  SOLICITUD_ENVIADA
  SOLICITUD_OBSERVADA
  SOLICITUD_APROBADA
  SOLICITUD_RECHAZADA
  SOLICITUD_MENSAJE
  MODIFICACION_SOLICITADA
  MODIFICACION_APROBADA
  MODIFICACION_RECHAZADA
}

enum PrioridadNotificacion {
  BAJA
  NORMAL
  ALTA
  URGENTE
}

enum EventoAlerta {
  CAMBIO_ESTADO
  INCIDENTE
  DESVIO_RUTA
  TIEMPO_EXCESIVO
  DIFERENCIA_PESO
  RECHAZO_CARGA
  VENCIMIENTO
  ANOMALIA_GPS
}

enum EstadoAlerta {
  PENDIENTE
  EN_REVISION
  RESUELTA
  DESCARTADA
}

enum TipoAnomalia {
  DESVIO_RUTA
  TIEMPO_EXCESIVO
  VELOCIDAD_ANORMAL
  PARADA_PROLONGADA
  GPS_PERDIDO
  RUTA_NO_AUTORIZADA
}

enum SeveridadAnomalia {
  BAJA
  MEDIA
  ALTA
  CRITICA
}

// ========== ANALYTICS & LOGGING ==========

model AnalyticsLog {
  id              String      @id @default(cuid())
  timestamp       DateTime    @default(now())
  method          String
  path            String
  userAgent       String?
  ipAddress       String?
  userId          String?
  userEmail       String?
  statusCode      Int
  responseTimeMs  Int
  queryParams     String?
  requestBody     String?
  
  @@index([timestamp])
  @@index([userId])
  @@index([path])
  @@map("analytics_logs")
}

// ========== BLOCKCHAIN SELLOS ==========

model BlockchainSello {
  id              String    @id @default(cuid())
  manifiestoId    String
  tipo            String    // "GENESIS" | "CIERRE"
  hash            String
  txHash          String?
  blockNumber     Int?
  blockTimestamp  DateTime?
  status          String    @default("PENDIENTE") // PENDIENTE | CONFIRMADO | ERROR
  retries         Int       @default(0)
  createdAt       DateTime  @default(now())
  manifiesto      Manifiesto @relation(fields: [manifiestoId], references: [id], onDelete: Cascade)

  @@index([manifiestoId])
  @@index([status])
  @@index([hash])
  @@unique([manifiestoId, tipo])
  @@map("blockchain_sellos")
}

// ========== GENERADOR FISCAL & DOCUMENTOS ==========

model PagoTEF {
  id               String    @id @default(cuid())
  generadorId      String?
  operadorId       String?
  anio             Int
  montoTEF         Float?
  resolucion       String?
  notificado       Boolean   @default(false)
  fechaNotificado  DateTime?
  fechaPago        DateTime?
  pagoFueraTermino Boolean   @default(false)
  habilitado       Boolean?
  gedoNotificacion String?
  gedoResolucion   String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  generador Generador? @relation(fields: [generadorId], references: [id], onDelete: Cascade)
  operador  Operador?  @relation(fields: [operadorId], references: [id], onDelete: Cascade)

  @@unique([generadorId, anio])
  @@unique([operadorId, anio])
  @@index([generadorId])
  @@index([operadorId])
  @@map("pagos_tef")
}

model DeclaracionJurada {
  id                String    @id @default(cuid())
  generadorId       String?
  operadorId        String?
  anio              Int
  numeroGDE         String?
  presentada        Boolean   @default(false)
  fechaPresentacion DateTime?
  ticketPago        String?
  observaciones     String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  generador Generador? @relation(fields: [generadorId], references: [id], onDelete: Cascade)
  operador  Operador?  @relation(fields: [operadorId], references: [id], onDelete: Cascade)

  @@unique([generadorId, anio])
  @@unique([operadorId, anio])
  @@index([generadorId])
  @@index([operadorId])
  @@map("declaraciones_juradas")
}

model Documento {
  id            String    @id @default(cuid())
  generadorId   String?
  operadorId    String?
  tipo          String
  nombre        String
  path          String
  mimeType      String
  size          Int
  anio          Int?
  estado        String    @default("PENDIENTE")
  observaciones String?
  subidoPor     String
  revisadoPor   String?
  revisadoAt    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  generador Generador? @relation(fields: [generadorId], references: [id], onDelete: Cascade)
  operador  Operador?  @relation(fields: [operadorId], references: [id], onDelete: Cascade)

  @@index([generadorId])
  @@index([operadorId])
  @@map("documentos")
}

// ========== RENOVACION ANUAL ==========

model Renovacion {
  id                String    @id @default(cuid())
  anio              Int
  tipoActor         String    // "GENERADOR" | "OPERADOR"
  generadorId       String?
  operadorId        String?
  modalidad         String    // "SIN_CAMBIOS" | "CON_CAMBIOS"
  estado            String    @default("PENDIENTE") // PENDIENTE | APROBADA | RECHAZADA
  datosActuales     String?   // JSON snapshot
  datosNuevos       String?   // JSON proposed (solo CON_CAMBIOS)
  camposModificados String?   // JSON ["domicilio","corrientesY"]
  tefAnterior       Float?
  tefNuevo          Float?
  revisadoPor       String?
  fechaRevision     DateTime?
  observaciones     String?
  motivoRechazo     String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  generador Generador? @relation(fields: [generadorId], references: [id], onDelete: Cascade)
  operador  Operador?  @relation(fields: [operadorId], references: [id], onDelete: Cascade)

  @@unique([anio, generadorId])
  @@unique([anio, operadorId])
  @@index([anio])
  @@index([estado])
  @@map("renovaciones")
}

// ========== DEMO ACCESS CONTROL ==========

model DemoAccess {
  id              String      @id @default(cuid())
  sessionId       String      @unique
  ipAddress       String?
  userAgent       String?
  accessGranted   DateTime    @default(now())
  lastActivity    DateTime    @default(now())

  @@index([sessionId])
  @@map("demo_access")
}

// ========== SOLICITUD DE INSCRIPCION ==========

enum EstadoSolicitud {
  BORRADOR
  ENVIADA
  EN_REVISION
  OBSERVADA
  APROBADA
  RECHAZADA
}

model SolicitudInscripcion {
  id                String            @id @default(cuid())
  usuarioId         String
  tipoActor         String            // "GENERADOR" | "OPERADOR" | "TRANSPORTISTA"
  estado            EstadoSolicitud   @default(BORRADOR)
  datosActor        String            // JSON completo del wizard
  datosResiduos     String?           // JSON corrientes/residuos
  datosTEF          String?           // JSON calculo TEF
  datosRegulatorio  String?           // JSON expediente, resolucion, etc.
  fechaEnvio        DateTime?
  fechaRevision     DateTime?
  revisadoPor       String?
  motivoRechazo     String?
  observaciones     String?
  generadorId       String?   @unique // ID del actor creado al aprobar
  operadorId        String?   @unique // ID del actor creado al aprobar
  transportistaId   String?   @unique // ID del actor creado al aprobar
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  usuario           Usuario           @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  documentos        DocumentoSolicitud[]
  mensajes          MensajeSolicitud[]

  @@index([usuarioId])
  @@index([estado])
  @@index([tipoActor, estado])
  @@map("solicitudes_inscripcion")
}

model DocumentoSolicitud {
  id              String    @id @default(cuid())
  solicitudId     String
  tipo            String    // "MEMORIA_TECNICA", "CONSTANCIA_AFIP", etc.
  nombre          String
  path            String
  mimeType        String
  size            Int
  estado          String    @default("PENDIENTE") // PENDIENTE | APROBADO | RECHAZADO
  observaciones   String?
  revisadoPor     String?
  revisadoAt      DateTime?
  createdAt       DateTime  @default(now())

  solicitud       SolicitudInscripcion @relation(fields: [solicitudId], references: [id], onDelete: Cascade)

  @@index([solicitudId])
  @@map("documentos_solicitud")
}

model MensajeSolicitud {
  id              String    @id @default(cuid())
  solicitudId     String
  autorId         String
  autorRol        String    // "ADMIN" | "CANDIDATO"
  contenido       String
  leido           Boolean   @default(false)
  leidoAt         DateTime?
  createdAt       DateTime  @default(now())

  solicitud       SolicitudInscripcion @relation(fields: [solicitudId], references: [id], onDelete: Cascade)

  @@index([solicitudId, createdAt])
  @@map("mensajes_solicitud")
}

// ── Email Queue ─────────────────────────────────────────────────────

enum EmailTipo {
  TRANSACCIONAL
  ALERTA
}

enum EmailPrioridad {
  CRITICA
  NORMAL
  BAJA
}

enum EmailEstado {
  PENDIENTE
  ENVIADO
  FALLIDO
  DIGEST_PENDIENTE
  SUPRIMIDO
}

model PushSubscripcion {
  id        String   @id @default(cuid())
  usuarioId String
  endpoint  String   @unique
  p256dh    String
  auth      String
  userAgent String?
  createdAt DateTime @default(now())
  usuario   Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@index([usuarioId])
  @@map("push_subscripciones")
}

model EmailQueue {
  id          String         @id @default(cuid())
  to          String
  subject     String
  html        String         @db.Text
  tipo        EmailTipo
  prioridad   EmailPrioridad @default(NORMAL)
  estado      EmailEstado    @default(PENDIENTE)
  intentos    Int            @default(0)
  maxIntentos Int            @default(3)
  error       String?
  digestKey   String?
  createdAt   DateTime       @default(now())
  sentAt      DateTime?
  nextRetryAt DateTime?

  @@index([estado, nextRetryAt])
  @@index([to, createdAt])
  @@index([digestKey])
  @@map("email_queue")
}

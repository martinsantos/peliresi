generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Usuario {
  id                    String              @id @default(cuid())
  email                 String              @unique
  password              String
  rol                   Rol
  cuit                  String?             @unique
  nombre                String
  apellido              String?
  empresa               String?
  telefono              String?
  activo                Boolean             @default(true)
  dosFaSecret           String?
  dosFaVerificado       Boolean             @default(false)
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  aprobado              Boolean             @default(true)
  aprobadoPorId         String?
  fechaAprobacion       DateTime?
  fechaSolicitud        DateTime?
  motivoRechazo         String?
  motivoSolicitud       String?
  alertasResueltas      AlertaSeguridad[]   @relation("AlertasResueltas")
  alertasSeguridad      AlertaSeguridad[]   @relation("AlertasUsuario")
  auditorias            Auditoria[]         @relation("UsuarioAuditorias")
  eventos               EventoManifiesto[]
  generador             Generador?
  logsActividad         LogActividad[]
  manifiestosCreados    Manifiesto[]        @relation("UsuarioManifiestos")
  notificaciones        Notificacion[]
  operador              Operador?
  preferencias          PreferenciaUsuario?
  pushSubscriptions     PushSubscription[]
  refreshTokens         RefreshToken[]
  reglasCreadas         ReglaAlerta[]       @relation("ReglasCreadas")
  reversionesRealizadas ReversionEstado[]
  transportista         Transportista?

  @@index([rol])
  @@index([activo])
  @@index([rol, activo])
  @@map("usuarios")
}

model Generador {
  id                String       @id @default(cuid())
  usuarioId         String       @unique
  razonSocial       String
  cuit              String       @unique
  domicilio         String
  telefono          String
  email             String
  numeroInscripcion String
  categoria         String
  activo            Boolean      @default(true)
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  latitud           Float?
  longitud          Float?

  // Nuevos campos de inscripción
  certificado              String?    // Número de certificado (G - 000001)
  expedienteInscripcion    String?    // Expediente electrónico (EX-2018-...)
  resolucionInscripcion    String?    // Número de resolución (262/2008)

  // Datos de actividad
  actividad                String?    // Descripción de actividad económica
  rubro                    String?    // Sector industrial

  // Domicilio Legal (separado)
  domicilioLegalCalle      String?
  domicilioLegalLocalidad  String?
  domicilioLegalDepartamento String?

  // Domicilio Real (separado)
  domicilioRealCalle       String?
  domicilioRealLocalidad   String?
  domicilioRealDepartamento String?

  // Certificaciones y clasificación
  certificacionIso         String?    // Número de certificación ISO
  clasificacion            String?    // MINIMA, INDIVIDUAL, etc.

  // Datos de cumplimiento
  informeTecnico           String?
  tef                      String?    // Registro TEF
  libroOperatoria          Boolean?   // SI/NO

  // Referencias a DDJJ por año
  ddjj2021                 String?
  ddjj2022                 String?
  ddjj2023                 String?
  ddjj2024                 String?
  ddjjAbril2024            String?
  ddjj2025                 String?
  ddjj2026                 String?

  // Métricas de residuos
  residuosR                String?    // R
  residuosMxR              String?    // M x R

  // Control de calidad de datos
  cuitValido               Boolean    @default(true)  // false si CUIT fue reemplazado por @@@@@@

  usuario           Usuario      @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  manifiestos       Manifiesto[]

  @@index([certificado])
  @@index([rubro])
  @@index([clasificacion])
  @@map("generadores")
}

model Transportista {
  id                 String       @id @default(cuid())
  usuarioId          String       @unique
  razonSocial        String
  cuit               String       @unique
  domicilio          String
  telefono           String
  email              String
  numeroHabilitacion String
  activo             Boolean      @default(true)
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  choferes           Chofer[]
  manifiestos        Manifiesto[]
  usuario            Usuario      @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  vehiculos          Vehiculo[]

  @@map("transportistas")
}

model Operador {
  id                 String                  @id @default(cuid())
  usuarioId          String                  @unique
  razonSocial        String
  cuit               String                  @unique
  domicilio          String
  telefono           String
  email              String
  numeroHabilitacion String
  categoria          String
  activo             Boolean                 @default(true)
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt
  latitud            Float?
  longitud           Float?
  manifiestos        Manifiesto[]
  usuario            Usuario                 @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  tratamientos       TratamientoAutorizado[]

  @@map("operadores")
}

model Vehiculo {
  id                 String        @id @default(cuid())
  transportistaId    String
  patente            String
  marca              String
  modelo             String
  anio               Int
  capacidad          Float
  numeroHabilitacion String
  vencimiento        DateTime
  activo             Boolean       @default(true)
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  transportista      Transportista @relation(fields: [transportistaId], references: [id], onDelete: Cascade)

  @@map("vehiculos")
}

model Chofer {
  id              String        @id @default(cuid())
  transportistaId String
  nombre          String
  apellido        String
  dni             String
  licencia        String
  vencimiento     DateTime
  telefono        String
  activo          Boolean       @default(true)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  transportista   Transportista @relation(fields: [transportistaId], references: [id], onDelete: Cascade)

  @@map("choferes")
}

model TipoResiduo {
  id              String                  @id @default(cuid())
  codigo          String                  @unique
  nombre          String
  descripcion     String?
  categoria       String
  caracteristicas String?
  peligrosidad    String
  activo          Boolean                 @default(true)
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt
  manifiestos     ManifiestoResiduo[]
  tratamientos    TratamientoAutorizado[]

  @@map("tipos_residuos")
}

model Manifiesto {
  id              String               @id @default(cuid())
  numero          String               @unique
  generadorId     String
  transportistaId String
  operadorId      String
  estado          EstadoManifiesto     @default(BORRADOR)
  observaciones   String?
  fechaCreacion   DateTime             @default(now())
  fechaFirma      DateTime?
  fechaRetiro     DateTime?
  fechaEntrega    DateTime?
  fechaRecepcion  DateTime?
  fechaCierre     DateTime?
  qrCode          String?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  creadoPorId     String
  firmaDigital    Json?
  alertas         AlertaGenerada[]
  anomalias       AnomaliaTransporte[]
  auditorias      Auditoria[]
  eventos         EventoManifiesto[]
  creadoPor       Usuario              @relation("UsuarioManifiestos", fields: [creadoPorId], references: [id])
  generador       Generador            @relation(fields: [generadorId], references: [id])
  operador        Operador             @relation(fields: [operadorId], references: [id])
  transportista   Transportista        @relation(fields: [transportistaId], references: [id])
  residuos        ManifiestoResiduo[]
  notificaciones  Notificacion[]
  reversiones     ReversionEstado[]
  tracking        TrackingGPS[]
  viajes          Viaje[]

  @@index([estado])
  @@index([estado, createdAt])
  @@index([generadorId])
  @@index([transportistaId])
  @@index([operadorId])
  @@index([createdAt])
  @@map("manifiestos")
}

model ManifiestoResiduo {
  id               String          @id @default(cuid())
  manifiestoId     String
  tipoResiduoId    String
  cantidad         Float
  unidad           String
  descripcion      String?
  estado           String
  createdAt        DateTime        @default(now())
  cantidadRecibida Float?
  observaciones    String?
  tipoDiferencia   TipoDiferencia?
  manifiesto       Manifiesto      @relation(fields: [manifiestoId], references: [id], onDelete: Cascade)
  tipoResiduo      TipoResiduo     @relation(fields: [tipoResiduoId], references: [id])

  @@index([manifiestoId])
  @@index([tipoResiduoId])
  @@map("manifiestos_residuos")
}

model EventoManifiesto {
  id           String     @id @default(cuid())
  manifiestoId String
  tipo         String
  descripcion  String
  ubicacion    String?
  latitud      Float?
  longitud     Float?
  usuarioId    String
  createdAt    DateTime   @default(now())
  manifiesto   Manifiesto @relation(fields: [manifiestoId], references: [id], onDelete: Cascade)
  usuario      Usuario    @relation(fields: [usuarioId], references: [id])

  @@index([manifiestoId])
  @@index([tipo])
  @@index([createdAt])
  @@map("eventos_manifiesto")
}

model TrackingGPS {
  id           String     @id @default(cuid())
  manifiestoId String
  latitud      Float
  longitud     Float
  velocidad    Float?
  direccion    Float?
  precision    Float?
  timestamp    DateTime   @default(now())
  manifiesto   Manifiesto @relation(fields: [manifiestoId], references: [id], onDelete: Cascade)

  @@index([manifiestoId])
  @@index([manifiestoId, timestamp])
  @@index([timestamp])
  @@map("tracking_gps")
}

model TratamientoAutorizado {
  id            String      @id @default(cuid())
  operadorId    String
  tipoResiduoId String
  metodo        String
  descripcion   String?
  capacidad     Float
  activo        Boolean     @default(true)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  operador      Operador    @relation(fields: [operadorId], references: [id], onDelete: Cascade)
  tipoResiduo   TipoResiduo @relation(fields: [tipoResiduoId], references: [id])

  @@unique([operadorId, tipoResiduoId, metodo])
  @@map("tratamientos_autorizados")
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  usuarioId String
  revocado  Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  usuario   Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

model Auditoria {
  id           String      @id @default(cuid())
  accion       String
  modulo       String
  datosAntes   String?
  datosDespues String?
  ip           String?
  userAgent    String?
  usuarioId    String
  manifiestoId String?
  createdAt    DateTime    @default(now())
  manifiesto   Manifiesto? @relation(fields: [manifiestoId], references: [id])
  usuario      Usuario     @relation("UsuarioAuditorias", fields: [usuarioId], references: [id])

  @@map("auditorias")
}

model Notificacion {
  id           String                @id @default(cuid())
  usuarioId    String
  tipo         TipoNotificacion
  titulo       String
  mensaje      String
  datos        String?
  manifiestoId String?
  leida        Boolean               @default(false)
  fechaLeida   DateTime?
  prioridad    PrioridadNotificacion @default(NORMAL)
  createdAt    DateTime              @default(now())
  manifiesto   Manifiesto?           @relation(fields: [manifiestoId], references: [id])
  usuario      Usuario               @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@index([usuarioId, leida])
  @@map("notificaciones")
}

model ReglaAlerta {
  id               String           @id @default(cuid())
  nombre           String
  descripcion      String?
  evento           EventoAlerta
  condicion        String
  destinatarios    String
  activa           Boolean          @default(true)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  creadoPorId      String
  alertasGeneradas AlertaGenerada[]
  creadoPor        Usuario          @relation("ReglasCreadas", fields: [creadoPorId], references: [id])

  @@map("reglas_alertas")
}

model AlertaGenerada {
  id              String       @id @default(cuid())
  reglaId         String
  manifiestoId    String?
  datos           String
  estado          EstadoAlerta @default(PENDIENTE)
  resueltaPor     String?
  fechaResolucion DateTime?
  notas           String?
  createdAt       DateTime     @default(now())
  manifiesto      Manifiesto?  @relation(fields: [manifiestoId], references: [id])
  regla           ReglaAlerta  @relation(fields: [reglaId], references: [id])

  @@map("alertas_generadas")
}

model AnomaliaTransporte {
  id              String            @id @default(cuid())
  manifiestoId    String
  tipo            TipoAnomalia
  descripcion     String
  latitud         Float
  longitud        Float
  valorDetectado  Float?
  valorEsperado   Float?
  severidad       SeveridadAnomalia @default(MEDIA)
  resuelta        Boolean           @default(false)
  resueltaPor     String?
  fechaResolucion DateTime?
  notas           String?
  createdAt       DateTime          @default(now())
  manifiesto      Manifiesto        @relation(fields: [manifiestoId], references: [id])

  @@map("anomalias_transporte")
}

model AnalyticsLog {
  id             String   @id @default(cuid())
  timestamp      DateTime @default(now())
  method         String
  path           String
  userAgent      String?
  ipAddress      String?
  userId         String?
  userEmail      String?
  statusCode     Int
  responseTimeMs Int
  queryParams    String?
  requestBody    String?

  @@index([timestamp])
  @@index([userId])
  @@index([path])
  @@map("analytics_logs")
}

model DemoAccess {
  id            String   @id @default(cuid())
  sessionId     String   @unique
  ipAddress     String?
  userAgent     String?
  accessGranted DateTime @default(now())
  lastActivity  DateTime @default(now())

  @@index([sessionId])
  @@map("demo_access")
}

model PushSubscription {
  id        String   @id @default(cuid())
  usuarioId String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
  usuario   Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@index([usuarioId])
  @@map("push_subscriptions")
}

model LogActividad {
  id             String       @id @default(cuid())
  usuarioId      String
  accion         String
  modulo         String
  entidadId      String?
  detalles       Json?
  ip             String?
  userAgent      String?
  timestamp      DateTime     @default(now())
  datosAntes     Json?
  datosDespues   Json?
  duracionMs     Int?
  resultadoExito Boolean      @default(true)
  severidad      SeveridadLog @default(INFO)
  usuario        Usuario      @relation(fields: [usuarioId], references: [id])

  @@index([usuarioId])
  @@index([accion])
  @@index([modulo])
  @@index([timestamp])
  @@index([severidad])
  @@index([usuarioId, timestamp])
  @@map("log_actividad")
}

model Viaje {
  id              String      @id @default(cuid())
  manifiestoId    String
  transportistaId String
  usuarioId       String
  inicio          DateTime
  fin             DateTime?
  duracion        Int?
  distancia       Float?
  estado          EstadoViaje @default(EN_CURSO)
  ruta            Json?
  eventos         Json?
  dispositivoId   String?
  appVersion      String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  pausas          Int         @default(0)
  ultimaPausa     DateTime?
  manifiesto      Manifiesto  @relation(fields: [manifiestoId], references: [id])

  @@index([manifiestoId])
  @@index([transportistaId])
  @@index([usuarioId])
  @@index([estado])
  @@index([inicio])
  @@map("viajes")
}

model PreferenciaUsuario {
  id                String   @id @default(cuid())
  usuarioId         String   @unique
  mostrarTourInicio Boolean  @default(true)
  ultimaVersionTour String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  usuario           Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@map("preferencias_usuario")
}

model ReversionEstado {
  id             String           @id @default(cuid())
  manifiestoId   String
  estadoAnterior EstadoManifiesto
  estadoNuevo    EstadoManifiesto
  motivo         String
  tipoReversion  TipoReversion
  usuarioId      String
  rolUsuario     Rol
  ip             String?
  userAgent      String?
  createdAt      DateTime         @default(now())
  manifiesto     Manifiesto       @relation(fields: [manifiestoId], references: [id])
  usuario        Usuario          @relation(fields: [usuarioId], references: [id])

  @@index([manifiestoId])
  @@index([usuarioId])
  @@index([createdAt])
  @@map("reversiones_estado")
}

model AlertaSeguridad {
  id                String              @id @default(cuid())
  tipo              TipoAlertaSeguridad
  descripcion       String
  usuarioAfectadoId String?
  datos             Json?
  severidad         SeveridadLog        @default(WARNING)
  resuelta          Boolean             @default(false)
  resueltaPorId     String?
  fechaResolucion   DateTime?
  notas             String?
  createdAt         DateTime            @default(now())
  resueltaPor       Usuario?            @relation("AlertasResueltas", fields: [resueltaPorId], references: [id])
  usuarioAfectado   Usuario?            @relation("AlertasUsuario", fields: [usuarioAfectadoId], references: [id])

  @@index([tipo])
  @@index([createdAt])
  @@index([resuelta])
  @@map("alertas_seguridad")
}

enum TipoDiferencia {
  FALTANTE
  EXCEDENTE
  NINGUNA
}

enum Rol {
  ADMIN
  GENERADOR
  TRANSPORTISTA
  OPERADOR
  ADMIN_TRANSPORTISTAS
  ADMIN_OPERADORES
  ADMIN_GENERADORES
}

enum EstadoManifiesto {
  BORRADOR
  PENDIENTE_APROBACION
  APROBADO
  EN_TRANSITO
  ENTREGADO
  RECIBIDO
  EN_TRATAMIENTO
  TRATADO
  RECHAZADO
  CANCELADO
}

enum TipoNotificacion {
  MANIFIESTO_FIRMADO
  MANIFIESTO_EN_TRANSITO
  MANIFIESTO_ENTREGADO
  MANIFIESTO_RECIBIDO
  MANIFIESTO_TRATADO
  MANIFIESTO_RECHAZADO
  INCIDENTE_REPORTADO
  ANOMALIA_DETECTADA
  VENCIMIENTO_PROXIMO
  ALERTA_SISTEMA
  INFO_GENERAL
  MANIFIESTO_PENDIENTE
  MANIFIESTO_APROBADO
}

enum PrioridadNotificacion {
  BAJA
  NORMAL
  ALTA
  URGENTE
}

enum EventoAlerta {
  CAMBIO_ESTADO
  INCIDENTE
  DESVIO_RUTA
  TIEMPO_EXCESIVO
  DIFERENCIA_PESO
  RECHAZO_CARGA
  VENCIMIENTO
  ANOMALIA_GPS
}

enum EstadoAlerta {
  PENDIENTE
  EN_REVISION
  RESUELTA
  DESCARTADA
}

enum TipoAnomalia {
  DESVIO_RUTA
  TIEMPO_EXCESIVO
  VELOCIDAD_ANORMAL
  PARADA_PROLONGADA
  GPS_PERDIDO
  RUTA_NO_AUTORIZADA
}

enum SeveridadAnomalia {
  BAJA
  MEDIA
  ALTA
  CRITICA
}

enum EstadoViaje {
  EN_CURSO
  COMPLETADO
  CANCELADO
  INCIDENTE
  PAUSADO
}

enum TipoReversion {
  RECHAZO_ENTREGA
  ERROR_TRANSPORTISTA
  REVISION_CERTIFICADO
  CORRECCION_ADMIN
}

enum SeveridadLog {
  DEBUG
  INFO
  WARNING
  ERROR
  CRITICAL
}

enum TipoAlertaSeguridad {
  MULTIPLES_LOGIN_FALLIDOS
  ACTIVIDAD_FUERA_HORARIO
  REVERSIONES_FRECUENTES
  IP_INUSUAL
  PATRON_ANOMALO
}

# ============================================================
# SITREP Backend — Plantilla de Variables de Entorno
# Copiar a .env y completar con valores reales.
# NUNCA commitear .env con credenciales reales.
# ============================================================

# ---- Entorno ----
NODE_ENV="development"           # development | production
PORT=3010                        # Puerto de escucha (PM2 usa 3010)

# ---- Base de datos ----
# Producción: trazabilidad_rrpp
# Desarrollo local: trazabilidad_dev (para no tocar prod accidentalmente)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/trazabilidad_dev?schema=public"

# ---- JWT ----
# REQUERIDO en producción: generar con `openssl rand -base64 64`
JWT_SECRET="CHANGE_ME_use_openssl_rand_base64_64"
JWT_EXPIRES_IN="24h"

# REQUERIDO en producción: token distinto al JWT_SECRET
JWT_REFRESH_SECRET="CHANGE_ME_another_random_secret"
JWT_REFRESH_EXPIRES_IN="7d"

# ---- CORS ----
# URL del frontend (sin slash final)
FRONTEND_URL="http://localhost:5173"
CORS_ORIGIN="http://localhost:5173"

# ---- Superadmin ----
# Email que puede acceder a endpoints /api/analytics/summary (solo estadísticas agregadas)
SUPER_ADMIN_EMAIL="admin@dgfa.mendoza.gov.ar"

# ---- Notificaciones (opcional) ----
ENABLE_ANALYTICS="true"

# ---- Email Queue + SMTP ----
# Kill switch: suprime envios SMTP pero sigue encolando en DB
DISABLE_EMAILS="false"

# Rate limits por destinatario por dia
EMAIL_DAILY_LIMIT_TRANSACCIONAL=10   # verificacion, password reset, aprobaciones
EMAIL_DAILY_LIMIT_ALERTA=6           # digests de alertas

# Flush timer (ms). Default 5 min.
EMAIL_FLUSH_INTERVAL_MS=300000

# Max intentos de envio antes de marcar SUPRIMIDO
EMAIL_MAX_RETRIES=3

# SMTP (Postfix local por defecto, o Brevo/Gmail)
SMTP_HOST="localhost"
SMTP_PORT=25
SMTP_USER=""                         # Brevo: "apikey" | Gmail: "tu-email@gmail.com"
SMTP_PASS=""                         # Brevo: "xkeysib-..." | Gmail: "app-password"
SMTP_FROM="SITREP <no-reply@sitrep.ultimamilla.com.ar>"

# ---- Blockchain (opcional) ----
# BLOCKCHAIN_PRIVATE_KEY=""          # Sepolia wallet private key
# BLOCKCHAIN_CONTRACT_ADDRESS=""     # Smart contract address
# BLOCKCHAIN_RPC_URL=""              # Sepolia RPC endpoint (Alchemy/Infura)

# ---- Logging ----
LOG_LEVEL="debug"                    # debug (dev) | info (prod)

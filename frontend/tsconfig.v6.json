{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "baseUrl": ".",
    "paths": {
      "@v6/*": ["src-v6/*"],
      "@design/*": ["src-v6/design-system/*"],
      "@components/*": ["src-v6/components/*"],
      "@pages/*": ["src-v6/pages/*"],
      "@hooks/*": ["src-v6/hooks/*"],
      "@utils/*": ["src-v6/utils/*"],
      "@types/*": ["src-v6/types/*"],
      "@layouts/*": ["src-v6/layouts/*"]
    }
  },
  "include": ["src-v6/**/*"],
  "references": [{ "path": "./tsconfig.node.json" }]
}

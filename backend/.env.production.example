# ====================================================
# SITREP - VARIABLES DE PRODUCCION
# ====================================================
# Copiar este archivo a .env en el servidor de produccion
# IMPORTANTE: No commitear .env con valores reales
# ====================================================

# Modo de ejecucion
NODE_ENV=production
PORT=3001

# ====================================================
# BASE DE DATOS (REQUERIDO)
# ====================================================
# Formato: postgresql://usuario:password@host:puerto/basedatos
DATABASE_URL="postgresql://sitrep_prod:CAMBIAR_PASSWORD@localhost:5432/sitrep_prod"

# ====================================================
# SEGURIDAD JWT (REQUERIDO)
# ====================================================
# Generar con: openssl rand -hex 32
JWT_SECRET="CAMBIAR_GENERAR_CON_OPENSSL_RAND_HEX_32"
JWT_EXPIRES_IN="24h"

# ====================================================
# FIRMA DIGITAL (REQUERIDO)
# ====================================================
# Secret para HMAC de firmas (hasta integracion PKI ONTI)
# Generar con: openssl rand -hex 32
SIGNATURE_SECRET="CAMBIAR_GENERAR_CON_OPENSSL_RAND_HEX_32"

# ====================================================
# CORS (REQUERIDO - HTTPS obligatorio en produccion)
# ====================================================
# Separar multiples origenes con coma
CORS_ORIGIN="https://sitrep.gob.ar,https://app.sitrep.gob.ar"

# ====================================================
# PUSH NOTIFICATIONS VAPID (REQUERIDO)
# ====================================================
# Generar con: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY="CAMBIAR_GENERAR_CON_WEB_PUSH"
VAPID_PRIVATE_KEY="CAMBIAR_GENERAR_CON_WEB_PUSH"

# ====================================================
# REDIS (OPCIONAL - recomendado para alta disponibilidad)
# ====================================================
# Si no se configura, el sistema usa memoria local (degraded mode)
REDIS_URL="redis://:PASSWORD@redis-host:6379"

# ====================================================
# EMAIL SMTP (OPCIONAL)
# ====================================================
SMTP_HOST="smtp.mailgun.org"
SMTP_PORT=587
SMTP_USER="postmaster@sitrep.gob.ar"
SMTP_PASS="CAMBIAR_API_KEY"
SMTP_FROM="SITREP <noreply@sitrep.gob.ar>"

# ====================================================
# CRON JOBS (se activan automaticamente en produccion)
# ====================================================
# ENABLE_CRON=true  # No necesario, se activa con NODE_ENV=production

# ====================================================
# GENERACION DE SECRETOS
# ====================================================
# Ejecutar estos comandos para generar valores seguros:
#
# JWT_SECRET y SIGNATURE_SECRET:
#   openssl rand -hex 32
#
# VAPID Keys:
#   npx web-push generate-vapid-keys
#
# Password PostgreSQL:
#   openssl rand -base64 24
#
# ====================================================
# NOTAS DE SEGURIDAD
# ====================================================
# - Demo Mode se bloquea automaticamente con NODE_ENV=production
# - El servidor NO inicia si faltan variables requeridas
# - CORS solo acepta origenes HTTPS en produccion
# - Logs de intentos de usar demo mode en produccion
# ====================================================

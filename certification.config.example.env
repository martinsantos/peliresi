# SITREP certification suite configuration.
# Copy values into your shell or CI secrets before running.

# quick | post-deploy | production-smoke | certification
RUN_PROFILE=quick

# Public target under test.
TARGET_URL=https://sitrep.ultimamilla.com.ar
API_URL=https://sitrep.ultimamilla.com.ar/api

# Evidence output.
REPORT_DIR=reports/test-runs

# Autocorrection policy.
# false by default; set true only in staging/test.
ALLOW_AUTOFIX=false

# Destructive staging policy.
# Required for tests that create/reset data or run restore drills.
ALLOW_DESTRUCTIVE_STAGING=false

# Optional snapshot/restore commands for staging certification runs.
# These commands run from the repository root.
STAGING_SNAPSHOT_COMMAND=
STAGING_RESTORE_COMMAND=

# Optional remote operational checks.
# Example: SSH_HOST=root@23.105.176.45
SSH_HOST=

# Frontend and soak tuning.
PLAYWRIGHT_PROJECT=chromium
SOAK_SECONDS=1800

# Network classification.
# In quick/local runs, registry/target network failures are warnings.
# In post-deploy, production-smoke, certification, or GitHub Actions, they block.
NETWORK_RETRIES=2
NETWORK_TIMEOUT=10
OFFLINE_SKIP_AUDIT=false
